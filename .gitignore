# ============================================
# TiendaQ — Consolidated .gitignore
# ============================================

# === OS ===
.DS_Store
Thumbs.db

# === IDE / Editors ===
.vscode/
!.vscode/extensions.json
.idea/
*.iws
*.iml
*.ipr
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
nbproject/private/
nbproject/build-impl.xml
nbproject/genfiles.properties

# === Java / Spring Boot ===
target/
!**/src/main/**/target/
!**/src/test/**/target/
*.class
*.jar
*.war
*.ear
.java-version
HELP.md

# === Java IDE Metadata (STS / Eclipse / NetBeans) ===
.apt_generated
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache
/nbbuild/
/nbdist/
/.nb-gradle/

# === Maven Wrapper ===
!.mvn/wrapper/maven-wrapper.jar

# === Node / Frontend ===
node_modules/
dist/
.angular/
*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# === Build Output ===
build/
!**/src/main/**/build/
!**/src/test/**/build/

# === Logs ===
logs/
*.log

# === Secrets ===
.env
.env.*
